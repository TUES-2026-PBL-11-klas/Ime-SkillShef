# ─── Build artifacts ───────────────────────────────────────────────────────────
# The 'target/' directory is generated during the Docker build itself.
# Including it in the build context would add hundreds of MB unnecessarily.
target/

# ─── Version control ────────────────────────────────────────────────────────────
.git/
.gitignore
.gitattributes

# ─── Documentation & local-only files ──────────────────────────────────────────
*.md
Documentation/

# ─── Secret / local environment files ──────────────────────────────────────────
# Never ship .env files into the Docker image.
.env
.env.local
.env.*.local

# ─── IDE & editor configuration ─────────────────────────────────────────────────
.idea/
.vscode/
*.iml
*.iws
*.ipr
.classpath
.project
.settings/
.springBeans
.factorypath
.apt_generated

# ─── OS artefacts ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Test reports & coverage ─────────────────────────────────────────────────────
surefire-reports/
jacoco.exec

# SkillChef API — environment variable reference
# Copy to .env for local development. Never commit .env.
#
# For Render (staging/prod): set these in the dashboard or via render.yaml.
# See render.yaml at the repo root for the full mapping.

# --- Database (local Docker or Render PostgreSQL) ---
DATABASE_URL="jdbc:postgresql://localhost:5432/skillchef"
DATABASE_USERNAME="skillchef"
DATABASE_PASSWORD="change_me"

# --- Spring profile: dev | staging | prod ---
SPRING_PROFILES_ACTIVE="dev"

# --- Auth / JWT ---
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET="dev-only-secret-change-me-in-prod-environment-please"
JWT_ISSUER="skillchef"
JWT_ACCESS_TTL="PT15M"
REFRESH_TTL="P30D"

# --- CORS: origin of the Next.js frontend ---
APP_BASE_URL="http://localhost:3000"

# --- Sentry error tracking ---
# Leave blank to disable locally. Get DSN: https://sentry.io → Project Settings → Client Keys
SENTRY_DSN=""
SENTRY_ENVIRONMENT="development"

# --- Logtail / Better Stack structured logging ---
# Leave blank locally (logs go to console). Get token: https://betterstack.com → Sources
# On Render prod, a Log Drain is an alternative to embedding the token here.
LOGTAIL_SOURCE_TOKEN=""

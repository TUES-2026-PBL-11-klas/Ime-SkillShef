# SkillChef API — environment variable reference
# Copy to .env for local development. Never commit .env.
#
# For Render (staging/prod): set these in the dashboard or via render.yaml.
# See render.yaml at the repo root for the full mapping and descriptions.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="jdbc:postgresql://localhost:5432/skillchef"
DATABASE_USERNAME="skillchef"
DATABASE_PASSWORD="change_me"

# ── Runtime profile: dev | staging | prod ─────────────────────────────────────
SPRING_PROFILES_ACTIVE="dev"

# ── Auth / JWT ────────────────────────────────────────────────────────────────
# Generate a strong secret locally: openssl rand -base64 32
# On Render this is auto-generated (generateValue: true in render.yaml).
JWT_SECRET="dev-only-secret-change-me-in-prod-environment-please"
JWT_ISSUER="skillchef"
JWT_ACCESS_TTL="PT15M"
REFRESH_TTL="P30D"

# ── CORS: origin of the Next.js frontend ──────────────────────────────────────
APP_BASE_URL="http://localhost:3000"

# ── Storage (Cloudflare R2 recommended; also compatible with AWS S3) ──────────
# Cloudflare R2:
#   STORAGE_ENDPOINT = https://<ACCOUNT_ID>.r2.cloudflarestorage.com
#   STORAGE_REGION   = auto
# AWS S3:
#   STORAGE_ENDPOINT = (leave blank)
#   STORAGE_REGION   = e.g. us-east-1
STORAGE_ENDPOINT=""
STORAGE_REGION="auto"
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""
STORAGE_BUCKET="skillchef-media"
# Public CDN URL for files: your R2 public bucket URL or custom domain
# e.g. https://pub-abc123.r2.dev  or  https://media.skillchef.com
STORAGE_CDN_BASE_URL=""
STORAGE_MAX_FILE_SIZE_MB="20"

# ── Sentry error tracking ──────────────────────────────────────────────────────
# Leave blank to disable locally. Get DSN: sentry.io → Project → Client Keys
SENTRY_DSN=""
SENTRY_ENVIRONMENT="development"

# ── Notifications / SendGrid ──────────────────────────────────────────────────
# Leave blank to disable email notifications locally.
# Get API key: app.sendgrid.com → Settings → API Keys
# Sender email must be verified in SendGrid.
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL="noreply@skillchef.com"
SENDGRID_FROM_NAME="SkillChef"

# ── Logtail / Better Stack ────────────────────────────────────────────────────
# Leave blank locally (logs go to the console).
# On Render prod, a Log Drain is the preferred approach over this token.
# Get token: betterstack.com → Logs → Sources
LOGTAIL_SOURCE_TOKEN=""

# SkillChef API — environment variable reference
# Copy to .env for local development. Never commit .env.
#
# For Render (staging/prod): set these in the dashboard or via render.yaml.
# See render.yaml at the repo root for the full mapping.

# --- Database (local Docker or Render PostgreSQL) ---
DATABASE_URL="jdbc:postgresql://localhost:5432/skillchef"
DATABASE_USERNAME="skillchef"
DATABASE_PASSWORD="change_me"

# --- Notifications / SendGrid ---
# Leave blank to disable email notifications locally.
# Get key: https://app.sendgrid.com → Settings → API Keys
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL="noreply@skillchef.com"
SENDGRID_FROM_NAME="SkillChef"

# --- Spring profile: dev | staging | prod ---
SPRING_PROFILES_ACTIVE="dev"

# --- Auth / JWT ---
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET="dev-only-secret-change-me-in-prod-environment-please"
JWT_ISSUER="skillchef"
JWT_ACCESS_TTL="PT15M"
REFRESH_TTL="P30D"

# --- CORS: origin of the Next.js frontend ---
APP_BASE_URL="http://localhost:3000"

# --- Sentry error tracking ---
# Leave blank to disable locally. Get DSN: https://sentry.io → Project Settings → Client Keys
SENTRY_DSN=""
SENTRY_ENVIRONMENT="development"

# --- Logtail / Better Stack structured logging ---
# Leave blank locally (logs go to console). Get token: https://betterstack.com → Sources
# On Render prod, a Log Drain is an alternative to embedding the token here.
LOGTAIL_SOURCE_TOKEN=""

# --- Redis (cache/queues) ---
REDIS_URL="redis://localhost:6379"

# --- File storage (avatars, etc.) ---
# Local-filesystem storage until Person 4's cloud storage SDK (S3 / R2) is wired in.
# STORAGE_LOCAL_DIR: directory on disk where uploaded files are written.
# STORAGE_PUBLIC_BASE_URL: public URL that maps to STORAGE_LOCAL_DIR (used to build returned URLs).
# STORAGE_MAX_FILE_SIZE: maximum accepted upload size, in bytes (default 5 MiB).
STORAGE_LOCAL_DIR="uploads"
STORAGE_PUBLIC_BASE_URL="http://localhost:8080/uploads"
STORAGE_MAX_FILE_SIZE="5242880"

# --- AI Chef Assistant (provider-agnostic chat client) ---
# Supported providers: gemini | groq | anthropic
# Leave AI_API_KEY blank to run the app without AI; calls then fail with a clear "not configured" error.
#
# Gemini (default): key from https://aistudio.google.com → Get API key
#   AI_PROVIDER="gemini"
#   AI_API_KEY=""
#   AI_MODEL="gemini-2.5-flash"
#   AI_BASE_URL="https://generativelanguage.googleapis.com/v1beta"
#
# Groq (free tier, no credit card): key from https://console.groq.com → API Keys
#   AI_PROVIDER="groq"
#   AI_API_KEY=""
#   AI_MODEL="llama-3.3-70b-versatile"   # or llama-3.1-8b-instant for faster/smaller
#   AI_BASE_URL="https://api.groq.com/openai/v1"
#   AI_REQUESTS_PER_MINUTE="30"          # Groq free tier: 30 RPM
#
# Anthropic: key from https://console.anthropic.com → API Keys
#   AI_PROVIDER="anthropic"
#   AI_API_KEY=""
#   AI_MODEL="claude-haiku-4-5-20251001"   # cheapest; use claude-opus-4-8 for best quality
#   AI_BASE_URL="https://api.anthropic.com/v1"
AI_PROVIDER="gemini"
AI_API_KEY=""
AI_MODEL="gemini-2.5-flash"
AI_BASE_URL="https://generativelanguage.googleapis.com/v1beta"
# Client-side request cap per minute (keep <= the provider quota; Gemini free tier ~15 RPM).
AI_REQUESTS_PER_MINUTE="15"
# Retry tuning for transient failures (429 / 5xx / timeout). Durations are ISO-8601 (PT0.5S = 500ms).
AI_MAX_RETRIES="3"
AI_RETRY_BACKOFF="PT0.5S"
AI_MAX_RETRY_BACKOFF="PT8S"
AI_CONNECT_TIMEOUT="PT5S"
AI_READ_TIMEOUT="PT30S"
# Default generation settings (overridable per request).
AI_TEMPERATURE="0.7"
AI_MAX_OUTPUT_TOKENS="1024"

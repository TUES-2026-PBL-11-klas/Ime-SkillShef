# SkillChef Client — environment variable reference
# Copy to .env.local for local development. Never commit .env.local.
#
# NEXT_PUBLIC_* vars are embedded in the browser bundle — never put secrets in them.
# For Render (staging/prod): set these in the dashboard or via render.yaml.

# --- API backend ---
# Local dev: http://localhost:8080
# Render prod: https://skillchef-api.onrender.com
NEXT_PUBLIC_API_URL="http://localhost:8080"

# --- Sentry error tracking ---
# Get DSN: https://sentry.io → Project Settings → Client Keys → DSN
NEXT_PUBLIC_SENTRY_DSN=""
# Auth token for source map uploads during build (not exposed to browser)
# Get: https://sentry.io → Organization Settings → Auth Tokens
SENTRY_AUTH_TOKEN=""
SENTRY_ENVIRONMENT="development"
# Sentry org slug and project name (visible in your Sentry project URL)
SENTRY_ORG=""
SENTRY_PROJECT=""

# --- PostHog product analytics ---
# Get key: https://app.posthog.com → Project Settings → API Keys
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.posthog.com"

# --- Logtail / Better Stack (Next.js server-side logs) ---
# Get token: https://betterstack.com → Sources
LOGTAIL_SOURCE_TOKEN=""
